# ===================================
# Family Plot - Environment Variables
# ===================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - only .env.example

# ------------------------------------
# Client-side Authentication
# ------------------------------------
# Enable additional passcode layer after Netlify Basic Auth
# false = Only Netlify auth (recommended for most families)
# true = Netlify auth + client-side passcode (extra layer)
ENABLE_CLIENT_SIDE_AUTH=false

# Passcode users must enter (only used when ENABLE_CLIENT_SIDE_AUTH=true)
# Change to your family's secret passcode
# Minimum 8 characters recommended
VITE_PASSCODE=

# ------------------------------------
# Future Feature Flags (reserved)
# ------------------------------------
# Add future feature flags here as needed
